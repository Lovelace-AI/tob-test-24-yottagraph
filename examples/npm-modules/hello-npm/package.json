{
    "name": "@aether-example/hello-npm",
    "version": "1.0.0",
    "description": "Example Aether module packaged as NPM",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./style.css": "./dist/style.css"
    },
    "scripts": {
        "build": "vite build && vue-tsc --emitDeclarationOnly",
        "dev": "vite build --watch",
        "type-check": "vue-tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "vue": "^3.0.0",
        "vue-router": "^4.0.0",
        "vuetify": "^3.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@vitejs/plugin-vue": "^4.5.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.7.0",
        "vite-plugin-vuetify": "^2.0.0",
        "vue": "^3.4.0",
        "vue-router": "^4.2.0",
        "vue-tsc": "^1.8.0",
        "vuetify": "^3.4.0"
    },
    "keywords": [
        "aether",
        "module",
        "vue",
        "vuetify"
    ],
    "author": "Aether Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/aether/modules"
    }
}
