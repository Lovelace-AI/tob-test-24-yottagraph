{
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "install": ". \"$NVM_DIR/nvm.sh\" && nvm install 20 && nvm alias default 20 && node init-project.js --local && npm install",
    "terminals": [
        {
            "name": "Dev Server",
            "command": "npm run dev",
            "port": 3000
        }
    ],
    "persistedDirectories": ["node_modules", ".nuxt", ".output"]
}
