{
    "name": "aether",
    "productName": "Aether",
    "version": "2.0.0",
    "description": "Build Lovelace AI applications in minutes, not days. A production-ready modular framework with event-driven architecture.",
    "main": "electron/main.js",
    "scripts": {
        "dev": "nuxt dev",
        "start": "node .output/server/index.mjs",
        "init": "node init-project.js",
        "prebuild": "npm run generate:elemental-client",
        "build": "NODE_ENV=production NODE_OPTIONS='--max-old-space-size=8192' nuxt build",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "generate:elemental-client": "orval --config ./orval.config.ts",
        "electron": "electron .",
        "electron:dev": "cross-env NODE_ENV=development electron .",
        "electron:serve": "node electron-dev.js",
        "electron:build": "npm run generate && electron-builder",
        "electron:build:win": "npm run generate && electron-builder --win",
        "electron:build:mac": "echo '⚠️  Warning: This command may auto-notarize if Apple credentials are in environment. Use electron:build:mac:signed or electron:build:mac:notarized for explicit behavior.' && npm run generate && electron-builder --mac",
        "electron:build:mac:signed": "npm run generate && env -i PATH=\"$PATH\" HOME=\"$HOME\" electron-builder --mac",
        "electron:build:mac:notarized": "npm run generate && electron-builder --mac",
        "electron:build:mac:unsigned": "npm run generate && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac",
        "electron:build:linux": "npm run generate && electron-builder --linux",
        "dist": "npm run generate && electron-builder",
        "dist:all": "npm run generate && electron-builder -mwl",
        "format": "prettier --write \"**/*.{js,ts,vue,json,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
        "add-module": "node scripts/add-external-module.js",
        "create-module": "node scripts/create-nuxt-module.js",
        "format:check": "prettier --check \"**/*.{js,ts,vue,json,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
        "postinstall": "npm run copy-spec && npx nuxi prepare && npm run generate:elemental-client",
        "copy-spec": "node scripts/copy-api-spec.js || true",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{js,ts,vue,json,md}": [
            "prettier --check"
        ]
    },
    "dependencies": {
        "@hapi/iron": "^7.0.1",
        "@yottagraph-ai/elemental-api": "^0.4.1",
        "@tanstack/vue-virtual": "^3.13.8",
        "chroma-js": "^3.1.2",
        "cors": "^2.8.5",
        "d3": "^7.8.5",
        "dagre": "^0.8.5",
        "electron-store": "^8.2.0",
        "express": "^4.18.2",
        "file-saver": "^2.0.5",
        "firebase": "^11.3.0",
        "firebase-admin": "^13.1.0",
        "iron-webcrypto": "^1.2.1",
        "jose": "^5.9.6",
        "localforage": "^1.10.0",
        "mitt": "^3.0.1",
        "prettier": "^3.5.3",
        "vuetify": "^3.8.5"
    },
    "devDependencies": {
        "@mdi/font": "^7.4.47",
        "@types/chroma-js": "^3.1.1",
        "@types/d3": "^7.4.3",
        "@types/dagre": "^0.7.52",
        "@types/file-saver": "^2.0.7",
        "@types/node": "^22.13.4",
        "@vitejs/plugin-vue": "^5.2.1",
        "cross-env": "^7.0.3",
        "dotenv": "^17.2.1",
        "electron": "^33.3.1",
        "electron-builder": "^25.1.8",
        "electron-builder-notarize": "^1.5.2",
        "electron-reload": "^2.0.0-alpha.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.6",
        "nuxt": "^3.16.0",
        "orval": "^7.3.0",
        "sass": "^1.84.0",
        "typescript": "^5.7.3",
        "vue": "^3.5.14",
        "vue-router": "^4.5.1",
        "vercel": "^50.13.2",
        "vuetify-nuxt-module": "^0.18.6"
    },
    "build": {
        "appId": "com.yourcompany.aether",
        "productName": "Aether",
        "directories": {
            "output": "dist-electron"
        },
        "files": [
            "electron/**/*",
            "server/**/*",
            ".output/public/**/*",
            "!**/*.map",
            "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
            "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
            "!**/node_modules/*.d.ts",
            "!**/node_modules/.bin"
        ],
        "asar": true,
        "compression": "maximum",
        "mac": {
            "category": "public.app-category.productivity",
            "icon": "build/icon.icns",
            "hardenedRuntime": true,
            "gatekeeperAssess": true,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.plist",
            "signIgnore": [
                "Electron Framework.framework/Versions/A/Resources/.*\\.lproj",
                "Electron Framework.framework/Versions/Current/Resources/.*\\.lproj"
            ],
            "target": "dmg"
        },
        "win": {
            "icon": "build/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "linux": {
            "icon": "build",
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "category": "Network"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
