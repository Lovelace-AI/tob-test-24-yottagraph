# Aether Application Configuration
# Generated by init script on 3/5/2026, 8:45:26 PM

# App Identity (REQUIRED - Must be unique per app!)
NUXT_PUBLIC_APP_ID=
NUXT_PUBLIC_APP_NAME=

# Deploy target: 'electron' for desktop app, 'vercel' for web deployment
DEPLOY_TARGET=

# Query Server Configuration
# Leave empty if not using the query server
NUXT_PUBLIC_QUERY_SERVER_ADDRESS=

# Cesium Configuration
# NUXT_PUBLIC_CESIUM_ACCESS_TOKEN=

# User configuration
# When using Auth0, NUXT_PUBLIC_USER_NAME must be empty
NUXT_PUBLIC_USER_NAME=

# Auth0 Configuration
NUXT_PUBLIC_AUTH0_CLIENT_ID=
# NUXT_PUBLIC_AUTH0_CLIENT_SECRET=
NUXT_PUBLIC_AUTH0_AUDIENCE=
